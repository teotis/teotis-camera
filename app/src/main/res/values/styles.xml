<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- TextAppearances -->

    <style name="TextAppearance.OpenCamera.Title" parent="TextAppearance.MaterialComponents.Body1">
        <item name="android:textColor">@color/oc_text_primary</item>
        <item name="android:textSize">@dimen/text_size_title</item>
        <item name="android:textStyle">bold</item>
        <item name="android:maxLines">1</item>
        <item name="android:ellipsize">end</item>
    </style>

    <style name="TextAppearance.OpenCamera.Status" parent="TextAppearance.MaterialComponents.Body2">
        <item name="android:textColor">@color/oc_text_secondary</item>
        <item name="android:textSize">@dimen/text_size_status</item>
        <item name="android:maxLines">1</item>
        <item name="android:ellipsize">end</item>
    </style>

    <style name="TextAppearance.OpenCamera.PanelTitle" parent="TextAppearance.MaterialComponents.Headline6">
        <item name="android:textColor">@color/oc_text_primary</item>
        <item name="android:textSize">@dimen/text_size_panel_title</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="TextAppearance.OpenCamera.SectionTitle" parent="TextAppearance.MaterialComponents.Subtitle1">
        <item name="android:textColor">@color/oc_text_primary</item>
        <item name="android:textSize">@dimen/text_size_section_title</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="TextAppearance.OpenCamera.SupportText" parent="TextAppearance.MaterialComponents.Body2">
        <item name="android:textColor">@color/oc_text_secondary</item>
        <item name="android:textSize">@dimen/text_size_support</item>
    </style>

    <style name="TextAppearance.OpenCamera.HeroSummary" parent="TextAppearance.MaterialComponents.Body2">
        <item name="android:textColor">@color/oc_accent</item>
        <item name="android:textSize">@dimen/text_size_support</item>
        <item name="android:fontFamily">monospace</item>
    </style>

    <style name="TextAppearance.OpenCamera.Footer" parent="TextAppearance.MaterialComponents.Caption">
        <item name="android:textColor">@color/oc_text_muted</item>
        <item name="android:textSize">@dimen/text_size_support</item>
    </style>

    <style name="TextAppearance.OpenCamera.EditingHint" parent="TextAppearance.MaterialComponents.Caption">
        <item name="android:textColor">@color/oc_accent</item>
        <item name="android:textSize">@dimen/text_size_support</item>
    </style>

    <style name="TextAppearance.OpenCamera.DevConsole" parent="TextAppearance.MaterialComponents.Body2">
        <item name="android:textColor">@color/oc_text_secondary</item>
        <item name="android:textSize">@dimen/text_size_dev_log</item>
        <item name="android:fontFamily">monospace</item>
    </style>

    <style name="TextAppearance.OpenCamera.CaptureOutput" parent="TextAppearance.MaterialComponents.Caption">
        <item name="android:textColor">@color/oc_text_secondary</item>
        <item name="android:textSize">@dimen/text_size_status</item>
        <item name="android:maxLines">1</item>
        <item name="android:ellipsize">end</item>
    </style>
</resources>
