<resources>
    <style name="Theme.OpenCamera" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="android:statusBarColor">@android:color/black</item>
        <item name="android:navigationBarColor">@android:color/black</item>
    </style>

    <style name="Widget.OpenCamera.CompactButton" parent="Widget.MaterialComponents.Button.OutlinedButton">
        <item name="android:textAllCaps">false</item>
        <item name="android:textColor">#F5F7FA</item>
        <item name="strokeColor">#70F5F7FA</item>
        <item name="backgroundTint">#221D242D</item>
    </style>

    <style name="Widget.OpenCamera.PillButton" parent="Widget.MaterialComponents.Button.OutlinedButton">
        <item name="android:textAllCaps">false</item>
        <item name="android:textColor">#F7FAFF</item>
        <item name="strokeColor">#805EE7FF</item>
        <item name="backgroundTint">#33111A24</item>
        <item name="cornerRadius">24dp</item>
    </style>

    <style name="Widget.OpenCamera.SettingsButton" parent="Widget.MaterialComponents.Button.OutlinedButton">
        <item name="android:textAllCaps">false</item>
        <item name="android:textColor">#F7FAFF</item>
        <item name="strokeColor">#40F7FAFF</item>
        <item name="backgroundTint">#1AFFFFFF</item>
        <item name="android:gravity">start|center_vertical</item>
        <item name="android:insetLeft">0dp</item>
        <item name="android:insetRight">0dp</item>
        <item name="android:minHeight">68dp</item>
        <item name="cornerRadius">18dp</item>
    </style>

    <style name="Widget.OpenCamera.ModeTrackButton" parent="Widget.MaterialComponents.Button.TextButton">
        <item name="android:textAllCaps">false</item>
        <item name="android:textColor">#F5F7FA</item>
        <item name="android:textSize">13sp</item>
        <item name="android:minWidth">0dp</item>
        <item name="android:minHeight">36dp</item>
        <item name="android:paddingStart">14dp</item>
        <item name="android:paddingEnd">14dp</item>
        <item name="android:insetTop">0dp</item>
        <item name="android:insetBottom">0dp</item>
        <item name="backgroundTint">#00000000</item>
    </style>

    <style name="Widget.OpenCamera.ModeTrackButton.Active">
        <item name="android:textColor">#FFFFFF</item>
        <item name="android:textStyle">bold</item>
        <item name="backgroundTint">#33FFFFFF</item>
    </style>

    <style name="Widget.OpenCamera.QuickSettingButton" parent="Widget.MaterialComponents.Button.OutlinedButton">
        <item name="android:textAllCaps">false</item>
        <item name="android:textColor">#D7E2F2</item>
        <item name="android:textSize">11sp</item>
        <item name="strokeColor">#30F5F7FA</item>
        <item name="backgroundTint">#15FFFFFF</item>
        <item name="android:minWidth">0dp</item>
        <item name="android:minHeight">0dp</item>
        <item name="android:paddingStart">10dp</item>
        <item name="android:paddingEnd">10dp</item>
        <item name="android:paddingTop">6dp</item>
        <item name="android:paddingBottom">6dp</item>
        <item name="cornerRadius">16dp</item>
    </style>

    <style name="Widget.OpenCamera.DevEntryButton" parent="Widget.MaterialComponents.Button.OutlinedButton">
        <item name="android:textAllCaps">false</item>
        <item name="android:textColor">#7FE4FF</item>
        <item name="android:textStyle">bold</item>
        <item name="strokeColor">#557FE4FF</item>
        <item name="backgroundTint">#15121B22</item>
        <item name="android:minWidth">0dp</item>
        <item name="android:minHeight">0dp</item>
        <item name="android:paddingStart">10dp</item>
        <item name="android:paddingEnd">10dp</item>
        <item name="android:paddingTop">6dp</item>
        <item name="android:paddingBottom">6dp</item>
        <item name="cornerRadius">14dp</item>
    </style>

    <style name="Widget.OpenCamera.DevConsolePanel" parent="Widget.MaterialComponents.CardView">
        <item name="cardBackgroundColor">#EC0F141D</item>
        <item name="cardCornerRadius">28dp</item>
        <item name="cardElevation">10dp</item>
    </style>
</resources>
