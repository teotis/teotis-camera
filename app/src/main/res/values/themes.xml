<resources>
    <style name="Theme.OpenCamera" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="android:statusBarColor">@android:color/black</item>
        <item name="android:navigationBarColor">@android:color/black</item>
    </style>

    <style name="Widget.OpenCamera.CompactButton" parent="Widget.MaterialComponents.Button.OutlinedButton">
        <item name="android:textAllCaps">false</item>
        <item name="android:textColor">@color/oc_text_primary</item>
        <item name="strokeColor">@color/oc_divider</item>
        <item name="backgroundTint">@color/oc_surface_panel_alt</item>
    </style>

    <style name="Widget.OpenCamera.PillButton" parent="Widget.MaterialComponents.Button.OutlinedButton">
        <item name="android:textAllCaps">false</item>
        <item name="android:textColor">@color/oc_text_primary</item>
        <item name="strokeColor">@color/oc_accent</item>
        <item name="backgroundTint">@color/oc_surface_panel_alt</item>
        <item name="cornerRadius">@dimen/radius_chip</item>
    </style>

    <style name="Widget.OpenCamera.SettingsButton" parent="Widget.MaterialComponents.Button.OutlinedButton">
        <item name="android:textAllCaps">false</item>
        <item name="android:textColor">@color/oc_text_primary</item>
        <item name="strokeColor">@color/oc_divider</item>
        <item name="backgroundTint">@color/oc_divider</item>
        <item name="android:gravity">start|center_vertical</item>
        <item name="android:insetLeft">0dp</item>
        <item name="android:insetRight">0dp</item>
        <item name="android:minHeight">@dimen/control_row_min_height</item>
        <item name="cornerRadius">@dimen/radius_small_button</item>
    </style>

    <style name="Widget.OpenCamera.ModeTrackButton" parent="Widget.MaterialComponents.Button.TextButton">
        <item name="android:textAllCaps">false</item>
        <item name="android:textColor">@color/oc_text_secondary</item>
        <item name="android:textSize">@dimen/text_size_mode_chip</item>
        <item name="android:minWidth">@dimen/mode_chip_min_width</item>
        <item name="android:minHeight">@dimen/mode_chip_min_height</item>
        <item name="android:paddingStart">@dimen/space_12</item>
        <item name="android:paddingEnd">@dimen/space_12</item>
        <item name="android:insetTop">0dp</item>
        <item name="android:insetBottom">0dp</item>
        <item name="android:singleLine">true</item>
        <item name="android:maxLines">1</item>
        <item name="android:ellipsize">end</item>
        <item name="backgroundTint">@android:color/transparent</item>
    </style>

    <style name="Widget.OpenCamera.ModeTrackButton.Active">
        <item name="android:textColor">@color/oc_text_primary</item>
        <item name="android:textStyle">bold</item>
        <item name="backgroundTint">@color/oc_surface_panel_alt</item>
    </style>

    <style name="Widget.OpenCamera.QuickSettingButton" parent="Widget.MaterialComponents.Button.OutlinedButton">
        <item name="android:textAllCaps">false</item>
        <item name="android:textColor">@color/oc_text_secondary</item>
        <item name="android:textSize">@dimen/text_size_zoom_chip</item>
        <item name="strokeColor">@color/oc_divider</item>
        <item name="backgroundTint">@color/oc_divider</item>
        <item name="android:minWidth">0dp</item>
        <item name="android:minHeight">0dp</item>
        <item name="android:paddingStart">@dimen/space_8</item>
        <item name="android:paddingEnd">@dimen/space_8</item>
        <item name="android:paddingTop">@dimen/space_4</item>
        <item name="android:paddingBottom">@dimen/space_4</item>
        <item name="cornerRadius">@dimen/radius_chip</item>
    </style>

    <style name="Widget.OpenCamera.DevEntryButton" parent="Widget.MaterialComponents.Button.OutlinedButton">
        <item name="android:textAllCaps">false</item>
        <item name="android:textColor">@color/oc_accent</item>
        <item name="android:textStyle">bold</item>
        <item name="strokeColor">@color/oc_divider</item>
        <item name="backgroundTint">@color/oc_surface_scrim_light</item>
        <item name="android:minWidth">0dp</item>
        <item name="android:minHeight">0dp</item>
        <item name="android:paddingStart">@dimen/space_8</item>
        <item name="android:paddingEnd">@dimen/space_8</item>
        <item name="android:paddingTop">@dimen/space_4</item>
        <item name="android:paddingBottom">@dimen/space_4</item>
        <item name="cornerRadius">@dimen/radius_small_button</item>
    </style>

    <style name="Widget.OpenCamera.DevConsolePanel" parent="Widget.MaterialComponents.CardView">
        <item name="cardBackgroundColor">@color/oc_surface_panel</item>
        <item name="cardCornerRadius">@dimen/radius_bottom_cockpit</item>
        <item name="cardElevation">10dp</item>
    </style>

    <style name="Widget.OpenCamera.RightRailButton" parent="Widget.MaterialComponents.Button">
        <item name="android:textAllCaps">false</item>
        <item name="android:textColor">@color/oc_text_primary</item>
        <item name="android:textSize">@dimen/text_size_right_rail</item>
        <item name="backgroundTint">@color/oc_surface_scrim</item>
        <item name="cornerRadius">@dimen/radius_small_button</item>
        <item name="android:minWidth">0dp</item>
        <item name="android:minHeight">0dp</item>
        <item name="android:insetLeft">0dp</item>
        <item name="android:insetRight">0dp</item>
        <item name="android:paddingStart">@dimen/space_4</item>
        <item name="android:paddingEnd">@dimen/space_4</item>
    </style>

    <style name="Widget.OpenCamera.RightRailDevButton" parent="Widget.MaterialComponents.Button.OutlinedButton">
        <item name="android:textAllCaps">false</item>
        <item name="android:textColor">@color/oc_accent</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textSize">@dimen/text_size_right_rail</item>
        <item name="strokeColor">@color/oc_divider</item>
        <item name="backgroundTint">@color/oc_surface_scrim_light</item>
        <item name="cornerRadius">@dimen/radius_small_button</item>
        <item name="android:minWidth">0dp</item>
        <item name="android:minHeight">0dp</item>
        <item name="android:insetLeft">0dp</item>
        <item name="android:insetRight">0dp</item>
    </style>

    <style name="Widget.OpenCamera.QuickBubbleButton" parent="Widget.MaterialComponents.Button">
        <item name="android:textAllCaps">false</item>
        <item name="android:textColor">@color/oc_text_primary</item>
        <item name="android:textSize">@dimen/text_size_status</item>
        <item name="backgroundTint">@color/oc_surface_scrim</item>
        <item name="cornerRadius">@dimen/radius_chip</item>
        <item name="android:minWidth">0dp</item>
        <item name="android:minHeight">0dp</item>
    </style>
</resources>
